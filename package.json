{
  "name": "@tscircuit/schematic-viewer",
  "version": "2.0.74",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "cosmos",
    "build": "tsup-node ./lib/index.ts --dts --format esm --sourcemap",
    "prepare": "bun ./scripts/prepare-git-dependency.ts",
