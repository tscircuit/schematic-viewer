    "format:check": "biome format ."
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "@types/debug": "^4.1.12",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.1.0",
    "react-cosmos": "^6.2.1",
    "react-cosmos-plugin-vite": "^6.2.0",
    "react-dom": "^19.1.0",
    "react-reconciler": "^0.31.0",
    "semver": "^7.7.2",
    "tscircuit": "^0.0.2112",
    "tsup": "^8.3.5",
    "vite": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0",
    "tscircuit": "*"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "circuit-json": "github:tscircuit/circuit-json#6804b9a31f4944cec30250004f7dda8539e720ed",
    "circuit-to-svg": "github:tscircuit/circuit-to-svg#87f5e9a53591913e4ad58357c1f67b6b06adf717",
    "debug": "^4.4.0",
    "performance-now": "^2.1.0",
    "use-mouse-matrix-transform": "^1.2.2"
  },
  "trustedDependencies": ["circuit-json", "circuit-to-svg", "esbuild"]
